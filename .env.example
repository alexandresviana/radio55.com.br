# Credenciais de acesso ao site
AUTH_USERNAME=admin
AUTH_PASSWORD=troque-esta-senha

# Segredo para assinar a sessão (gere uma string aleatória longa)
AUTH_SECRET=troque-por-um-segredo-aleatorio-de-pelo-menos-32-caracteres

# PostgreSQL — índice e busca de gravações MP3
DATABASE_URL=postgresql://usuario:senha@host:5432/postgres

# Diretório de dados dentro do container (padrão: /app/data)
# No Bunny Magic Containers, monte o volume em /app/data — NÃO em /radio55-data
# Se já montou em outro path, defina DATA_DIR com o mesmo valor do Mount path
# DATA_DIR=/app/data

# Transcrição automática (faster-whisper — modelo embutido na imagem, copiado para o volume no boot)
# WHISPER_ENABLED=true
# WHISPER_MODEL=base
# WHISPER_CACHE_DIR=/app/data/whisper-cache
# HF_TOKEN=hf_...  (opcional — aumenta limite de download no Hugging Face)
# Não use /opt/whisper-models — remova essa env no Bunny se ainda existir

# Monitoramento de canais do YouTube (legendas via youtube-transcript-plus)
# YOUTUBE_ENABLED=true

# Backup de MP3 para Bunny Storage (https://docs.bunny.net/api-reference/storage)
# Use a senha da Storage Zone (FTP & API Access), não a API key da conta
# BUNNY_STORAGE_ZONE=radio55-gravacoes
# BUNNY_STORAGE_ACCESS_KEY=sua-storage-zone-password
# BUNNY_STORAGE_REGION=br
# BUNNY_STORAGE_PATH_PREFIX=radio55/gravacoes
# BUNNY_STORAGE_INTERVAL_MS=1800000

# Docker Compose (opcional — sobrescreve valores acima)
# AUTH_USERNAME=admin
# AUTH_PASSWORD=sua_senha_forte
# AUTH_SECRET=segredo_longo_aleatorio
# DATABASE_URL=postgresql://usuario:senha@host:5432/postgres
