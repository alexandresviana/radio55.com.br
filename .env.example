# Credenciais de acesso ao site
AUTH_USERNAME=admin
AUTH_PASSWORD=troque-esta-senha

# Segredo para assinar a sessão (gere uma string aleatória longa)
AUTH_SECRET=troque-por-um-segredo-aleatorio-de-pelo-menos-32-caracteres
# Cookie Secure: auto (via X-Forwarded-Proto), ou force true/false
# COOKIE_SECURE=false

# PostgreSQL — índice e busca de gravações MP3
DATABASE_URL=postgresql://usuario:senha@host:5432/postgres

# Diretório de dados dentro do container (padrão: /app/data)
#
# Bunny Magic Containers — volume persistente (obrigatório para gravação/transcrição):
#   Mount path: /app/data
#   Conteúdo esperado:
#     /app/data/emissoras.json      — cadastro de rádios (editável pelo admin)
#     /app/data/gravacoes/          — MP3 em gravação (antes do upload ao Bunny Storage)
#     /app/data/trechos/            — cache de clipes de detecção (~25 s cada)
#     /app/data/whisper-cache/      — modelo faster-whisper (copiado do boot da imagem)
#
# Se montou o volume em outro path, defina DATA_DIR com o mesmo valor do Mount path.
# DATA_DIR=/app/data
#
# MP3 finalizados vão para Bunny Storage (BUNNY_STORAGE_*). Trechos ficam só no volume;
# se o pod reiniciar sem volume, o app regenera trechos a partir do MP3 no storage.

# Transcrição automática (faster-whisper — modelo embutido na imagem, copiado para o volume no boot)
# WHISPER_ENABLED=true
# WHISPER_MODEL=base
# WHISPER_CACHE_DIR=/app/data/whisper-cache
# HF_TOKEN=hf_...  (opcional — aumenta limite de download no Hugging Face)
# Não use /opt/whisper-models — remova essa env no Bunny se ainda existir

# Monitoramento de canais do YouTube (legendas via youtube-transcript-plus)
# YOUTUBE_ENABLED=true

# Backup de MP3 para Bunny Storage (https://docs.bunny.net/api-reference/storage)
# Use a senha da Storage Zone (FTP & API Access), não a API key da conta
# BUNNY_STORAGE_ZONE=radio55-gravacoes
# BUNNY_STORAGE_ACCESS_KEY=sua-storage-zone-password
# BUNNY_STORAGE_REGION=br
# BUNNY_STORAGE_PATH_PREFIX=radio55/gravacoes
# BUNNY_STORAGE_INTERVAL_MS=300000
# URL pública do Pull Zone (opcional — redireciona reprodução para o CDN)
# BUNNY_STORAGE_CDN_BASE=https://sua-zona.b-cdn.net/radio55/gravacoes
# Após upload bem-sucedido, apaga o MP3 local para economizar disco no pod
# BUNNY_STORAGE_DELETE_LOCAL_AFTER_UPLOAD=true

# Rotação de arquivos MP3 (padrão: 1 hora). Fecha o MP3 com segurança e abre outro.
# RECORDING_ROTATE_MS=3600000

# Busca com IA (aba "Busca IA" no admin)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_BUSCA_LIMITE=20

# Docker Compose (opcional — sobrescreve valores acima)
# AUTH_USERNAME=admin
# AUTH_PASSWORD=sua_senha_forte
# AUTH_SECRET=segredo_longo_aleatorio
# DATABASE_URL=postgresql://usuario:senha@host:5432/postgres
